# UniAD compose env (copy to .env and adjust per host).

# image
IMAGE_REPO=docker.io/kingszun/uniad
IMAGE_TAG=cu118-py39-torch2.0.1

# host user (compose 가 host 와 동일 uid 로 container 진입 — 파일 권한 매칭)
USER_UID=1000
USER_GID=1000

# GPU 선택 ('all' | '"device=0"' | '"device=0,1"')
DOCKER_GPUS=all

# CUDA arch (host GPU 에 맞게 override 가능)
# 3060=8.6 / A100=8.0 / 4090=8.9 / H100=9.0
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0+PTX
CMAKE_CUDA_ARCHITECTURES=80;86;89;90

# shared memory (mmcv dataloader)
SHM_SIZE=16gb

# host data path (KAK-24 기준 default)
HOST_NUSCENES=/mnt/e/datasets/nuscenes
HOST_UNIAD_INFOS=/mnt/e/datasets/uniad/infos
HOST_UNIAD_OTHERS=/mnt/e/datasets/uniad/others
HOST_UNIAD_CKPTS=/mnt/e/datasets/uniad/ckpts

# RunPod ssh (root login). 비워두면 entrypoint root branch skip.
# PUBLIC_KEY=ssh-ed25519 AAAA...

# compose default command (override 시 sleep infinity 외 다른 entrypoint args)
COMPOSE_COMMAND=sleep infinity
